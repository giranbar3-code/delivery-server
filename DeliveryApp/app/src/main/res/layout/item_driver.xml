<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp"
    android:layoutDirection="rtl"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/surface_white"
    app:strokeWidth="1dp"
    app:strokeColor="@color/divider">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- السطر الأول: الاسم + الرقم + أزرار الاتصال -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_driver_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"/>

                <TextView
                    android:id="@+id/tv_driver_phone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_call_driver"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="6dp"
                    android:text="📞"
                    android:textSize="14sp"
                    android:padding="0dp"
                    android:minWidth="0dp"
                    android:visibility="gone"
                    android:backgroundTint="@color/surface_white"
                    app:cornerRadius="10dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/divider"
                    style="@style/Widget.MaterialComponents.Button.TextButton"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_whatsapp_driver"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="6dp"
                    android:text="💬"
                    android:textSize="14sp"
                    android:padding="0dp"
                    android:minWidth="0dp"
                    android:visibility="gone"
                    android:backgroundTint="@color/surface_white"
                    app:cornerRadius="10dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/divider"
                    style="@style/Widget.MaterialComponents.Button.TextButton"/>
            </LinearLayout>

        </LinearLayout>

        <!-- خط فاصل -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginBottom="8dp"/>

        <!-- السطر الثاني: الإحصائيات + أزرار التعديل والحذف -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_driver_stats"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:lineSpacingExtra="3dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_edit_driver"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginEnd="4dp"
                android:padding="0dp"
                android:minWidth="0dp"
                android:background="@null"
                app:icon="@drawable/ic_edit"
                app:iconSize="18dp"
                app:iconTint="@color/primary_blue"
                style="@style/Widget.MaterialComponents.Button.TextButton"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_delete_driver"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:padding="0dp"
                android:minWidth="0dp"
                android:background="@null"
                app:icon="@drawable/ic_delete"
                app:iconSize="18dp"
                app:iconTint="@color/status_cancelled"
                style="@style/Widget.MaterialComponents.Button.TextButton"/>
        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
